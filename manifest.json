{
  "manifest_version": 3,
  "name": "Conf Export Ext",
  "version": "1.0.0",
  "description": "Export a Confluence space to Markdown.",
  "author": "Christian Baumann <mail@christianbaumann.dev> (www.christianbaumann.dev)",
  "permissions": ["activeTab", "downloads", "offscreen", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Conf Export Ext"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
